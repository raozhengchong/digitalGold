# 根目录 Docker Compose 环境变量示例
# 用法：cp .env.docker.example .env 后按需修改

# --- 对外 URL（浏览器访问地址，生产环境改为 HTTPS 域名）---
MEDUSA_NODE_ENV=development
MEDUSA_PORT=9000
BACKEND_URL=http://localhost:9000
STOREFRONT_URL=http://localhost:8000
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000

# --- 安全（生产环境请使用强随机字符串）---
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
REVALIDATE_SECRET=supersecret

# --- Stripe ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- 对象存储（Docker 内网使用 minio 服务名，浏览器使用 localhost:9090）---
S3_FILE_URL=http://localhost:9090/medusa
S3_ACCESS_KEY_ID=medusaminio
S3_SECRET_ACCESS_KEY=medusaminio
S3_REGION=us-east-1
S3_BUCKET=medusa

# --- 邮件（Resend，可选）---
RESEND_API_KEY=
RESEND_FROM="Agilo <noreply@agilo.com>"

# --- MeiliSearch ---
MEILISEARCH_MASTER_KEY=yoursecretmasterkey
MEILISEARCH_API_KEY=yoursecretmasterkey

# --- Cookie（生产直连 HTTP 临时兼容开关）---
# HTTPS 正式环境建议设为 true，并移除该兼容配置
MEDUSA_COOKIE_SECURE=false
MEDUSA_COOKIE_SAME_SITE=lax

# --- Storefront 构建参数（NEXT_PUBLIC_* 在 docker build 时打入镜像）---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=us
# Stripe 公钥（构建必填；无 Stripe 账号可先用占位符通过构建，支付功能需换成真实 pk_test_...）
NEXT_PUBLIC_STRIPE_KEY=pk_test_placeholder
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_FEATURE_SEARCH_ENABLED=true
NEXT_PUBLIC_SEARCH_ENDPOINT=http://localhost:7700
NEXT_PUBLIC_SEARCH_API_KEY=
NEXT_PUBLIC_ENABLE_WEBMCP=
STOREFRONT_COOKIE_SECURE=false
STOREFRONT_COOKIE_SAME_SITE=lax
